ANTHROPIC_BASE_URL=http://localhost:20128/v1
# Use ONE auth method only:
# - ANTHROPIC_AUTH_TOKEN for Authorization: Bearer <token>
# - ANTHROPIC_API_KEY for X-Api-Key: <token>
ANTHROPIC_AUTH_TOKEN=sk-REPLACE_WITH_YOUR_NEW_TOKEN
# ANTHROPIC_API_KEY=sk-REPLACE_WITH_YOUR_NEW_TOKEN

# Remap Claude Code aliases to your gateway model IDs
ANTHROPIC_DEFAULT_OPUS_MODEL=cx/gpt-5.4
ANTHROPIC_DEFAULT_SONNET_MODEL=cx/gpt-5.4
ANTHROPIC_DEFAULT_HAIKU_MODEL=cx/gpt-5.4

# Optional if claude is already on PATH
CLAUDE_CLI_PATH=C:\Program Files\nodejs\claude.cmd